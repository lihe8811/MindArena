# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Neon Postgres connection string. Keep sslmode=require for Neon.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB_NAME?sslmode=require"

# Brave Search API key for web search in debate evidence gathering.
# Get your key at: https://api.search.brave.com/app/keys
BRAVE_API_KEY=""
