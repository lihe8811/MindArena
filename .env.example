# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Default database provider: Neon Postgres.
# Create a Neon project/database first, then paste the pooled connection string here.
# Keep sslmode=require for Neon.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB_NAME?sslmode=require"

# Optional: keep a direct connection string if you later need it for admin tasks.
# DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB_NAME?sslmode=require"

# Optional email delivery for account verification.
# If these are missing, verification codes fall back to the dev server log.
# RESEND_API_KEY="re_123"
# EMAIL_FROM="MindArena <no-reply@your-domain.com>"
